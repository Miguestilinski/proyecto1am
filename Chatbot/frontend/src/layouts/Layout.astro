---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-black text-slate-200 font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-Outfit: 'Outfit', sans-serif;
    --bg-primary: #0a0a0b;
    --bg-secondary: #111113;
    --bg-tertiary: #18181b;
    --bg-card: rgba(20, 20, 22, 0.7);
    --border-subtle: rgba(255, 255, 255, 0.06);
    --border-active: rgba(255, 255, 255, 0.12);
    --text-primary: #f4f4f5;
    --text-secondary: #a1a1aa;
    --text-muted: #71717a;
    --accent-teal: #14b8a6;
    --accent-teal-dim: rgba(20, 184, 166, 0.15);
    --accent-teal-glow: rgba(20, 184, 166, 0.4);
  }

  * {
    font-family: 'DM Sans', sans-serif;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Outfit', sans-serif;
  }

  ::-webkit-scrollbar {
    width: 5px;
  }

  ::-webkit-scrollbar-track {
    background: transparent;
  }

  ::-webkit-scrollbar-thumb {
    background: #27272a;
    border-radius: 3px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #3f3f46;
  }

  ::selection {
    background: var(--accent-teal-dim);
    color: var(--accent-teal);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 0 8px var(--accent-teal-glow);
    }
    50% {
      box-shadow: 0 0 16px var(--accent-teal-glow);
    }
  }

  @keyframes shimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.4s ease-out forwards;
  }

  .glass {
    background: var(--bg-card);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-subtle);
  }

  .glass-hover {
    transition: all 0.25s ease;
  }

  .glass-hover:hover {
    background: rgba(30, 30, 33, 0.8);
    border-color: var(--border-active);
  }
</style>